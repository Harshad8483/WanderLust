<% layout("/layouts/boilerplate") %>

<div class="container mt-4">

    <div class="row justify-content-center">

        <div class="col-lg-8">

            <!-- Listing Title -->
            <h2 class="fw-bold mb-3"><%= listing.title %></h2>

            <!-- Listing Card -->
            <div class="card show-card shadow-sm">

                <img
                    src="<%= listing.image.url %>"
                    class="card-img-top show-img"
                    alt="listing image">

                <div class="card-body">

                    <p class="card-text">
                        <%= listing.description %>
                    </p>

                    <h5 class="fw-bold">
                        ₹ <%= listing.price.toLocaleString("en-IN") %> / Night
                    </h5>

                    <p class="mb-1">
                        <%= listing.location %>
                    </p>

                    <p>
                        <%= listing.country %>
                    </p>

                    <div class="d-flex gap-3 mt-4">

                        <a
                            href="/listings/<%= listing._id %>/edit"
                            class="btn btn-add">
                            Edit
                        </a>

                        <form
                            method="POST"
                            action="/listings/<%= listing._id %>?_method=DELETE">

                            <button class="btn btn-dark">
                                Delete
                            </button>

                        </form>

                    </div>

                </div>

            </div>

            <!-- Review Form -->

            <div class="mt-5">

                <h4>Leave a Review</h4>

                <form
                    method="POST"
                    action="/listings/<%= listing._id %>/reviews"
                    class="needs-validation"
                    novalidate>

                    <div class="mb-3">

                        <label
                            for="rating"
                            class="form-label">

                            Rating

                        </label>

                        <input
                            type="range"
                            min="1"
                            max="5"
                            id="rating"
                            name="review[rating]"
                            class="form-range">

                    </div>

                    <div class="mb-3">

                        <label
                            for="comment"
                            class="form-label">

                            Comment

                        </label>

                        <textarea
                            class="form-control"
                            id="comment"
                            rows="4"
                            name="review[comment]"
                            required></textarea>

                        <div class="invalid-feedback">
                            Please enter a review.
                        </div>

                    </div>

                    <button class="btn btn-outline-dark">
                        Submit
                    </button>

                </form>

            </div>

            <!-- Reviews -->

            <div class="mt-5">

                <h3 class="mb-4">
                    All Reviews
                </h3>

                <% if(listing.reviews.length > 0){ %>

                <div class="row">

                    <% for(let review of listing.reviews){ %>

                    <div class="col-md-6 mb-4">

                        <div class="card review-card h-100 shadow-sm">

                            <div class="card-body">

                                <h5 class="card-title fw-bold">
                                    Guest
                                </h5>

                                <p class="card-text">
                                    <%= review.comment %>
                                </p>

                                <p class="text-muted mb-3">
                                    ⭐ <%= review.rating %> Stars
                                </p>

                                <form
                                    method="POST"
                                    action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE">

                                    <button
                                        class="btn btn-sm btn-outline-danger">

                                        Delete Review

                                    </button>

                                </form>

                            </div>

                        </div>

                    </div>

                    <% } %>

                </div>

                <% } else { %>

                <div class="alert alert-light border">

                    No reviews yet.

                </div>

                <% } %>

            </div>

        </div>

    </div>

</div>